---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  heroImage?: string;
  category?: string;
  tags?: string[];
}

const { title, description, pubDate, slug, heroImage, category, tags = [] } = Astro.props;

const dateStr = pubDate.toLocaleDateString('ja-JP', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow overflow-hidden group">
  <a href={`/posts/${slug}`} class="block">
    <!-- サムネイル -->
    <div class="relative overflow-hidden bg-gray-100 h-44 sm:h-48">
      {heroImage ? (
        <img
          src={heroImage}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="lazy"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary-100 to-primary-200">
          <svg class="w-12 h-12 text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
      )}

      {category && (
        <span class="absolute top-3 left-3 bg-primary-600 text-white text-xs font-semibold px-2.5 py-1 rounded-full shadow">
          {category}
        </span>
      )}
    </div>

    <!-- コンテンツ -->
    <div class="p-4">
      <h2 class="font-bold text-gray-900 text-base leading-snug mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
        {title}
      </h2>
      <p class="text-sm text-gray-500 leading-relaxed line-clamp-2 mb-3">
        {description}
      </p>
      <div class="flex items-center justify-between">
        <time class="text-xs text-gray-400 flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          {dateStr}
        </time>
        <span class="text-xs text-primary-600 font-medium flex items-center gap-0.5">
          続きを読む
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </div>
    </div>
  </a>
</article>
