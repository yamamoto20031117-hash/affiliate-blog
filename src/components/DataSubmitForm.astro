---
// データ投稿フォーム（コンパクト版: スクショ + 地図 + 乗り物）
---

<style>
  details[open] .details-arrow { transform: rotate(180deg); }
</style>

<div id="form-wrapper">

  <!-- 成功メッセージ -->
  <div id="success-msg" class="hidden bg-green-50 border border-green-200 rounded-2xl p-8 text-center">
    <div class="text-4xl mb-3">🎉</div>
    <p class="font-bold text-green-800 text-lg mb-1">データを送信しました！</p>
    <p id="success-sub" class="text-xs text-green-600 mb-4"></p>
    <button id="reset-btn" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded-lg text-sm font-semibold transition-colors">
      もう1件投稿する
    </button>
  </div>

  <!-- メインフォーム -->
  <form id="data-form" class="space-y-4">

    <!-- STEP 1: スクリーンショット -->
    <div class="bg-gradient-to-br from-violet-50 to-indigo-50 border border-violet-200 rounded-2xl p-4">
      <p class="text-sm font-bold text-violet-800 mb-2">📸 今日のスクショをアップロード</p>
      <p class="text-[10px] text-gray-500 mb-2">Uber Eatsアプリの売上画面を撮影してドロップ</p>

      <!-- 正しいスクショの選び方 -->
      <details class="mb-3 bg-amber-50/80 border border-amber-200 rounded-xl text-xs">
        <summary class="cursor-pointer px-3 py-2 text-amber-700 font-semibold flex items-center gap-1.5 select-none">
          <span>⚠️</span><span>どの画面を撮ればいい？</span>
          <svg class="w-3.5 h-3.5 ml-auto transition-transform details-arrow" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"/></svg>
        </summary>
        <div class="px-3 pb-3 space-y-2 text-[11px] leading-relaxed text-gray-700">
          <div class="flex gap-2">
            <div class="flex-1 bg-green-50 border border-green-300 rounded-lg p-2 text-center">
              <div class="text-lg mb-1">✅</div>
              <p class="font-bold text-green-700 text-[10px] mb-1">1日ごとの画面</p>
              <p class="text-[9px] text-gray-500 leading-tight"><strong>1日分</strong>の売上・時間・<br/>乗車回数が表示された状態</p>
            </div>
            <div class="flex-1 bg-red-50 border border-red-300 rounded-lg p-2 text-center">
              <div class="text-lg mb-1">❌</div>
              <p class="font-bold text-red-700 text-[10px] mb-1">1週間まとめの画面</p>
              <p class="text-[9px] text-gray-500 leading-tight">1週間の合計が表示された<br/>画面は曜日ごとのデータが<br/>取れないため使えません</p>
            </div>
          </div>
          <p class="text-[10px] text-amber-600 bg-amber-100/60 rounded-lg px-2 py-1.5 leading-relaxed">
            💡 <strong>売上画面の左上「<」ボタン</strong>で1日単位に切り替えられます。<strong>「◯月◯日」と1日の日付が表示</strong>されている画面をスクショしてください。
          </p>
        </div>
      </details>

      <div id="ocr-dropzone" class="border-2 border-dashed border-violet-300 rounded-xl p-6 text-center cursor-pointer hover:bg-violet-50 transition-colors">
        <input type="file" id="ocr-file" accept="image/*" class="hidden" />
        <div id="ocr-placeholder">
          <div class="text-3xl mb-2">📷</div>
          <p class="text-sm text-violet-600 font-semibold">タップまたはドラッグで画像を選択</p>
          <p class="text-[10px] text-gray-400 mt-1">売上・時間・件数を自動で読み取ります</p>
        </div>
        <div id="ocr-preview-img" class="hidden">
          <img id="ocr-thumb" class="max-h-40 mx-auto rounded-lg shadow-sm" />
          <p class="text-[10px] text-violet-500 mt-2">別の画像を選択するにはタップ</p>
        </div>
      </div>

      <!-- 処理中 -->
      <div id="ocr-processing" class="hidden text-center py-4">
        <p class="text-sm text-violet-600 font-semibold mb-2">🔍 画像を解析中...</p>
        <div class="w-full bg-gray-200 rounded-full h-1.5 overflow-hidden">
          <div id="ocr-progress-bar" class="bg-violet-500 h-1.5 rounded-full transition-all duration-300" style="width:0%"></div>
        </div>
      </div>

      <!-- 解析結果 -->
      <div id="ocr-result" class="hidden mt-3 space-y-3">
        <p class="text-xs font-bold text-gray-700">📊 解析結果（修正可能）</p>
        <div class="grid grid-cols-2 gap-2">
          <div>
            <label class="text-[10px] text-gray-500">売り上げ総額</label>
            <div class="relative">
              <input type="number" id="ocr-earnings" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-6" />
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400">円</span>
            </div>
          </div>
          <div>
            <label class="text-[10px] text-gray-500">時給</label>
            <div class="relative">
              <input type="text" id="ocr-hourly" readonly class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-emerald-600 bg-emerald-50 text-right pr-6" />
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400">/h</span>
            </div>
          </div>
          <div>
            <label class="text-[10px] text-gray-500">正味の料金</label>
            <div class="relative">
              <input type="number" id="ocr-base-fare" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-6" />
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400">円</span>
            </div>
          </div>
          <div>
            <label class="text-[10px] text-gray-500">プロモーション</label>
            <div class="relative">
              <input type="number" id="ocr-promotion" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-6" />
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400">円</span>
            </div>
          </div>
          <div>
            <label class="text-[10px] text-gray-500">チップ</label>
            <div class="relative">
              <input type="number" id="ocr-tip" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-6" />
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400">円</span>
            </div>
          </div>
          <div>
            <label class="text-[10px] text-gray-500">オンライン時間</label>
            <div class="flex gap-1">
              <div class="relative flex-1">
                <input type="number" id="ocr-hours" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-5" />
                <span class="absolute right-1.5 top-1/2 -translate-y-1/2 text-[10px] text-gray-400">h</span>
              </div>
              <div class="relative flex-1">
                <input type="number" id="ocr-minutes" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-5" />
                <span class="absolute right-1.5 top-1/2 -translate-y-1/2 text-[10px] text-gray-400">m</span>
              </div>
            </div>
          </div>
          <div>
            <label class="text-[10px] text-gray-500">配達件数</label>
            <div class="relative">
              <input type="number" id="ocr-deliveries" class="w-full border border-gray-200 rounded-lg px-2 py-1.5 text-sm font-bold text-right pr-6" />
              <span class="absolute right-2 top-1/2 -translate-y-1/2 text-xs text-gray-400">件</span>
            </div>
          </div>
        </div>
        <!-- 曜日セレクター -->
        <div>
          <label class="text-[10px] text-gray-500">配達した曜日（棒グラフで色の濃い日を選択）</label>
          <div id="ocr-dow-buttons" class="flex gap-1 mt-1">
            <button type="button" data-dow="mon" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-blue-50 transition-colors">月</button>
            <button type="button" data-dow="tue" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-blue-50 transition-colors">火</button>
            <button type="button" data-dow="wed" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-blue-50 transition-colors">水</button>
            <button type="button" data-dow="thu" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-blue-50 transition-colors">木</button>
            <button type="button" data-dow="fri" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-gray-600 hover:bg-blue-50 transition-colors">金</button>
            <button type="button" data-dow="sat" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-blue-600 hover:bg-blue-50 transition-colors">土</button>
            <button type="button" data-dow="sun" class="dow-btn flex-1 text-xs py-1.5 rounded-lg border border-gray-200 bg-white text-red-500 hover:bg-red-50 transition-colors">日</button>
          </div>
          <input type="hidden" id="ocr-dow" value="" />
        </div>
      </div>

      <!-- 週間画像警告 -->
      <div id="ocr-weekly-warning" class="hidden mt-3 bg-amber-50 border border-amber-300 rounded-xl p-3">
        <p class="text-sm font-bold text-amber-700">⚠️ 1週間まとめの画面です</p>
        <p class="text-xs text-amber-600 mt-1">この画像は1週間の合計データのため、曜日ごとの正確なデータが取れません。</p>
        <p class="text-xs text-amber-600 mt-0.5"><strong>1日分のデータ</strong>の画像をアップロードしてください。</p>
      </div>

      <p id="ocr-error" class="hidden text-xs text-red-500 text-center mt-2"></p>
    </div>

    <!-- STEP 2: 配達エリア -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
      <div class="flex items-center justify-between mb-2">
        <p class="text-sm font-bold text-gray-700">🗺️ 配達エリア</p>
        <span id="area-saved-badge" class="hidden text-[10px] text-emerald-500 bg-emerald-50 px-2 py-0.5 rounded-full">前回の設定を復元</span>
      </div>

      <!-- 選択中のエリアタグ -->
      <div id="city-tags" class="flex flex-wrap gap-1.5 min-h-[32px] border border-gray-200 rounded-lg px-2 py-1.5 bg-gray-50 mb-2">
        <span class="text-xs text-gray-400" id="city-tags-placeholder">地図からエリアを選んでください</span>
      </div>

      <!-- 地図ピッカー（常に表示） -->
      <div id="picker-wrap" class="rounded-xl border border-gray-200 overflow-hidden relative" style="height:280px;background:#dbeafe;">
        <svg id="picker-svg" style="width:100%;height:100%;display:block;cursor:pointer;"></svg>

        <div id="picker-nav" class="absolute top-2 left-2 z-10 flex gap-1">
          <button type="button" id="picker-btn-pref"
            class="bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors">
            🗾 都道府県
          </button>
          <button type="button" id="picker-btn-city"
            class="bg-white/95 text-gray-400 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors cursor-not-allowed" disabled>
            📍 市区町村
          </button>
        </div>

        <div id="picker-loading" class="absolute inset-0 flex items-center justify-center bg-blue-50/80 backdrop-blur-sm">
          <p class="text-sm text-slate-500">🗾 地図を読み込み中...</p>
        </div>
      </div>
      <p id="picker-hint" class="text-[10px] text-gray-400 mt-1 text-center">都道府県をタップすると市区町村が表示されます</p>

      <!-- hidden fields for form data -->
      <input type="hidden" id="prefecture" name="prefecture" />
      <input type="hidden" id="city" name="city" />
      <input type="hidden" id="city-multi" name="city_multi" />
    </div>

    <!-- STEP 3: 乗り物 -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-4">
      <div class="flex items-center justify-between mb-2">
        <p class="text-sm font-bold text-gray-700">🚗 乗り物</p>
        <span id="vehicle-saved-badge" class="hidden text-[10px] text-emerald-500 bg-emerald-50 px-2 py-0.5 rounded-full">前回の設定を復元</span>
      </div>
      <div class="grid grid-cols-4 gap-2">
        {[
          ['walk_bicycle','🚲','自転車&徒歩'],
          ['moped50','🛵','原付(50cc)'],
          ['motorcycle','🏍️','バイク(51cc〜)'],
          ['kei_car','🚗','軽自動車'],
        ].map(([val, icon, label]) => (
          <label class="vehicle-label flex flex-col items-center gap-1 border rounded-xl px-2 py-3 cursor-pointer transition-colors text-xs border-gray-200 hover:border-gray-300">
            <input type="radio" name="vehicle" value={val} class="sr-only vehicle-radio" />
            <span class="text-xl">{icon}</span>
            <span class="text-center text-[10px] leading-tight">{label}</span>
          </label>
        ))}
      </div>
    </div>

    <!-- エラー・レート制限 -->
    <div id="error-msg" class="hidden bg-red-50 border border-red-200 rounded-lg px-4 py-3 text-sm text-red-700"></div>
    <div id="rate-limit-msg" class="hidden bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 text-sm text-gray-600">
      <p>⏳ 連続投稿の制限中です。<span id="rate-timer" class="font-bold"></span>後に再度投稿できます。</p>
    </div>

    <!-- 送信ボタン -->
    <button type="submit" id="submit-btn"
      class="w-full bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-600 hover:to-teal-600 text-white font-bold py-3.5 rounded-xl shadow-lg hover:shadow-xl transition-all text-base disabled:opacity-40 disabled:cursor-not-allowed"
      disabled>
      📤 データを送信する
    </button>
    <p class="text-[10px] text-gray-400 text-center">スクショ + エリア + 乗り物の3つで送信できます</p>

    <!-- ハニーポット -->
    <div style="position:absolute;left:-9999px;top:-9999px;">
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
    </div>
  </form>
</div>

<script>
  // ===== 状態管理 =====
  let formLoadTime = Date.now();
  const selectedCities = new Set<string>();
  let currentPickerPref = '';
  let pickerInCityMode = false;
  let ocrDataReady = false; // OCRデータが揃っているか

  // ===== 送信可否の更新 =====
  function updateSubmitState() {
    const hasOCR = ocrDataReady;
    const hasArea = selectedCities.size > 0;
    const hasVehicle = !!(document.querySelector('input[name="vehicle"]:checked') as HTMLInputElement)?.value;
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    btn.disabled = !(hasOCR && hasArea && hasVehicle);
  }

  // ===== localStorage復元: 配達エリア & 乗り物 =====
  function restoreSavedPrefs() {
    // 乗り物
    const savedVehicle = localStorage.getItem('uber_pref_vehicle');
    if (savedVehicle) {
      const radio = document.querySelector(`input[name="vehicle"][value="${savedVehicle}"]`) as HTMLInputElement;
      if (radio) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
        document.getElementById('vehicle-saved-badge')!.classList.remove('hidden');
      }
    }
    // 配達エリア（県名 + 市区町村リスト）
    const savedPref = localStorage.getItem('uber_pref_prefecture');
    const savedCities = localStorage.getItem('uber_pref_cities');
    if (savedPref && savedCities) {
      try {
        const cities = JSON.parse(savedCities) as string[];
        if (cities.length > 0) {
          (document.getElementById('prefecture') as HTMLInputElement).value = savedPref;
          currentPickerPref = savedPref;
          cities.forEach(c => selectedCities.add(c));
          updateCityTags();
          document.getElementById('area-saved-badge')!.classList.remove('hidden');
        }
      } catch {}
    }
    updateSubmitState();
  }

  function savePrefToStorage() {
    const vehicle = (document.querySelector('input[name="vehicle"]:checked') as HTMLInputElement)?.value;
    if (vehicle) localStorage.setItem('uber_pref_vehicle', vehicle);
    if (currentPickerPref) localStorage.setItem('uber_pref_prefecture', currentPickerPref);
    if (selectedCities.size > 0) localStorage.setItem('uber_pref_cities', JSON.stringify([...selectedCities]));
  }

  // ===== 乗り物ラジオボタン =====
  document.querySelectorAll('.vehicle-radio').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('.vehicle-label').forEach(l => {
        l.classList.remove('border-blue-500', 'bg-blue-50', 'text-blue-700', 'font-semibold');
        l.classList.add('border-gray-200');
      });
      const label = radio.closest('label')!;
      label.classList.add('border-blue-500', 'bg-blue-50', 'text-blue-700', 'font-semibold');
      label.classList.remove('border-gray-200');
      savePrefToStorage();
      updateSubmitState();
    });
  });

  // ===== 不正対策 =====
  function checkRateLimit(): { ok: boolean; waitSec: number } {
    const last = parseInt(localStorage.getItem('uber_last_submit') ?? '0');
    const cooldown = 30000;
    const elapsed = Date.now() - last;
    if (elapsed < cooldown) return { ok: false, waitSec: Math.ceil((cooldown - elapsed) / 1000) };
    return { ok: true, waitSec: 0 };
  }

  function checkDuplicate(entry: any): boolean {
    let data: any[] = [];
    try { data = JSON.parse(localStorage.getItem('uber_data') ?? '[]'); } catch {}
    return data.some((d: any) =>
      d.prefecture === entry.prefecture &&
      d.city === entry.city &&
      d.hours === entry.hours &&
      d.earnings === entry.earnings &&
      d.vehicle === entry.vehicle &&
      d.timestamp?.slice(0, 10) === new Date().toISOString().slice(0, 10)
    );
  }

  // ===== エリアタグ表示 =====
  function updateCityTags() {
    const container = document.getElementById('city-tags')!;
    const placeholder = document.getElementById('city-tags-placeholder')!;
    container.querySelectorAll('.city-tag').forEach(el => el.remove());
    if (selectedCities.size === 0) {
      placeholder.classList.remove('hidden');
    } else {
      placeholder.classList.add('hidden');
      selectedCities.forEach(name => {
        const tag = document.createElement('span');
        tag.className = 'city-tag inline-flex items-center gap-1 bg-emerald-100 text-emerald-700 rounded-full px-2 py-0.5 text-xs font-semibold';
        tag.innerHTML = `${name} <button type="button" class="ml-0.5 text-emerald-400 hover:text-red-500 text-xs font-bold" data-city="${name}">✕</button>`;
        tag.querySelector('button')!.addEventListener('click', () => {
          selectedCities.delete(name);
          updateCityTags();
          updatePickerHighlights();
          savePrefToStorage();
          updateSubmitState();
        });
        container.appendChild(tag);
      });
    }
    // hidden fieldsを更新
    const first = [...selectedCities][0] || '';
    (document.getElementById('city') as HTMLInputElement).value = first;
    (document.getElementById('city-multi') as HTMLInputElement).value = [...selectedCities].join(',');
  }

  function updatePickerHighlights() {
    if (!pickerD3) return;
    pickerD3.selectAll('.picker-cities path').each(function(d: any) {
      const name = cityFullNameGlobal(d);
      const el = pickerD3.select(this);
      if (selectedCities.has(name)) {
        el.attr('fill', '#34d399');
      } else {
        el.attr('fill', isUberArea(currentPickerPref, name) ? '#e8f4f8' : '#3f3f46');
      }
    });
  }

  // ===== Uber Eats 対応エリア =====
  const UBER_AREA: Record<string, Set<string>> = {
    '北海道': new Set(['札幌市','江別市','千歳市','恵庭市','石狩市','北広島市','旭川市','函館市','北斗市','釧路市','帯広市','苫小牧市','小樽市','室蘭市','登別市','岩見沢市','北見市','東神楽町','音更町','倶知安町','七飯町','南幌町','滝川市']),
    '青森': new Set(['青森市','八戸市','弘前市','むつ市','三沢市','平川市','六戸町','十和田市']),
    '岩手': new Set(['盛岡市','一関市','北上市','滝沢市','花巻市','奥州市']),
    '宮城': new Set(['仙台市','名取市','多賀城市','塩竈市','富谷市','利府町','石巻市','大崎市','大河原町','岩沼市','東松島市','登米市','松島町','七ヶ浜町','大和町','亘理町']),
    '秋田': new Set(['秋田市','大仙市','横手市','北秋田市','能代市','大館市','由利本荘市']),
    '山形': new Set(['山形市','鶴岡市','酒田市','天童市','東根市','米沢市','中山町','寒河江市']),
    '福島': new Set(['福島市','郡山市','いわき市','二本松市','会津若松市','南相馬市','猪苗代町','白河市','須賀川市','伊達市','相馬市']),
    '茨城': new Set(['水戸市','つくば市','土浦市','日立市','ひたちなか市','筑西市','牛久市','龍ケ崎市','取手市','守谷市','古河市','かすみがうら市','つくばみらい市','利根町','坂東市','常総市','東海村','神栖市','笠間市','結城市','那珂市','阿見町','鹿嶋市','茨城町','境町']),
