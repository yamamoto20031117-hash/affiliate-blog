  function pickerPrefName(props: any): string {
    let raw = '';
    if (props.nam_ja) raw = props.nam_ja;
    else if (props.name && /[\u3000-\u9fff]/.test(props.name)) raw = props.name;
    else if (props.nam && PICKER_ENG_TO_JA[props.nam]) return PICKER_ENG_TO_JA[props.nam];
    else raw = props.name ?? '';
    if (raw === '北海道') return '北海道';
    return raw.replace(/[都道府県]$/,'');
  }

  // 市区町村名ヘルパー（グローバル参照用）
  function cityFullNameGlobal(d: any): string {
    const gun = d.properties.N03_003 || '';
    const city = d.properties.N03_004 || '';
    return (gun && city) ? gun + city : city || gun;
  }

  let pickerD3: any = null;
  let pickerTopo: any = null;
  let pickerReady = false;

  async function initPicker() {
    const wrap = document.getElementById('picker-wrap')!;
    const W = wrap.offsetWidth, H = wrap.offsetHeight;
    // D3読み込み
    if (!(window as any).d3) {
      const s = document.createElement('script');
      s.src = 'https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js';
      document.head.appendChild(s);
      await new Promise<void>((res, rej) => { s.onload = () => res(); s.onerror = () => rej(); });
    }
    pickerD3 = (window as any).d3;

    // GeoJSON
    const prefData = await pickerD3.json('https://cdn.jsdelivr.net/gh/dataofjapan/land@master/japan.geojson');
    document.getElementById('picker-loading')!.style.display = 'none';

    const svg = pickerD3.select('#picker-svg');
    const proj = pickerD3.geoMercator().center([137.0, 37.5]).scale(1400).translate([W / 2, H / 2]);
    const path = pickerD3.geoPath().projection(proj);
    const gLayer = svg.append('g');

    // 都道府県描画
    gLayer.selectAll('path')
      .data(prefData.features)
      .enter().append('path')
      .attr('d', path)
      .attr('fill', '#e2e8f0')
      .attr('stroke', '#94a3b8')
      .attr('stroke-width', 0.5)
      .style('cursor', 'pointer')
      .on('mouseover', function() { pickerD3.select(this).attr('fill', '#bfdbfe'); })
      .on('mouseout', function() { pickerD3.select(this).attr('fill', '#e2e8f0'); })
      .on('click', function(_: any, d: any) {
        const name = pickerPrefName(d.properties);
        if (pickerInCityMode && currentPickerPref === name) return;
        if (pickerInCityMode) {
          gLayer.selectAll('.picker-cities').remove();
          svg.on('.zoom', null);
          pickerInCityMode = false;
        }
        (document.getElementById('prefecture') as HTMLInputElement).value = name;
        currentPickerPref = name;
        selectedCities.clear();
        updateCityTags();
        showCityPicker(name, path, gLayer, svg, W, H, d);
      });

    // ラベル
    gLayer.selectAll('text')
      .data(prefData.features)
      .enter().append('text')
      .attr('x', (d: any) => { try { return path.centroid(d)[0]; } catch { return 0; } })
      .attr('y', (d: any) => { try { return path.centroid(d)[1]; } catch { return 0; } })
      .attr('text-anchor', 'middle')
      .attr('font-size', '4px')
      .attr('fill', '#475569')
      .attr('pointer-events', 'none')
      .text((d: any) => pickerPrefName(d.properties));

    // ズーム
    const prefZoom = pickerD3.zoom().scaleExtent([1, 8])
      .on('zoom', (event: any) => {
        gLayer.attr('transform', event.transform);
        const k = event.transform.k;
        gLayer.selectAll('text').attr('font-size', `${7 / k}px`);
        gLayer.selectAll('path').attr('stroke-width', 0.5 / k);
      });
    svg.call(prefZoom);

    pickerReady = true;

    // 保存済みエリアがあれば地図にもドリルダウン
    if (currentPickerPref && selectedCities.size > 0) {
      const feat = prefData.features.find((f: any) => pickerPrefName(f.properties) === currentPickerPref);
      if (feat) {
        setTimeout(() => showCityPicker(currentPickerPref, path, gLayer, svg, W, H, feat), 300);
      }
    }
  }

  async function showCityPicker(
    prefName: string, pathFn: any, gLayer: any, svg: any, W: number, H: number, prefFeature: any
  ) {
    const code = PICKER_PREF_CODE[prefName];
    if (!code) return;

    gLayer.selectAll('.picker-cities').remove();
    pickerInCityMode = true;
    currentPickerPref = prefName;

    // ナビボタン更新
    const btnPref = document.getElementById('picker-btn-pref')!;
    const btnCity = document.getElementById('picker-btn-city')!;
    btnPref.className = 'bg-white/95 text-gray-700 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors hover:bg-gray-50 cursor-pointer';
    btnCity.className = 'bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors';
    btnCity.textContent = `📍 ${prefName}`;
    (btnCity as HTMLButtonElement).disabled = false;
    document.getElementById('picker-hint')!.textContent = '配達エリアをタップで選択（暗い地域はUber Eats非対応）';

    try {
      if (!pickerTopo) {
        if (!(window as any).topojson) {
          const s = document.createElement('script');
          s.src = 'https://cdn.jsdelivr.net/npm/topojson-client@3.1.0/dist/topojson-client.min.js';
          document.head.appendChild(s);
          await new Promise<void>((res, rej) => { s.onload = () => res(); s.onerror = () => rej(); });
        }
        pickerTopo = (window as any).topojson;
      }

      const urls = [
        `https://cdn.jsdelivr.net/gh/smartnews-smri/japan-topography@main/data/municipality/topojson/s0010/N03-21_${code}_210101.json`,
        `https://raw.githubusercontent.com/smartnews-smri/japan-topography/main/data/municipality/topojson/s0010/N03-21_${code}_210101.json`,
      ];
      let topo: any = null;
      for (const url of urls) {
        try { topo = await pickerD3.json(url); if (topo?.objects) break; } catch {}
      }
      if (!topo) throw new Error('取得失敗');

      const objKey = Object.keys(topo.objects)[0];
      const geoData = pickerTopo.feature(topo, topo.objects[objKey]);

      const features = geoData.features.filter((d: any) => {
        try {
          const c = pickerD3.geoCentroid(d);
          return c[1] >= 30 && c[1] <= 46 && c[0] >= 128 && c[0] <= 146;
        } catch { return false; }
      });

      // IQR離島除外でフィット
      const centroids: {x: number; y: number; f: any}[] = [];
      for (const f of features) {
        try {
          const c = pathFn.centroid(f);
          if (c && isFinite(c[0]) && isFinite(c[1])) centroids.push({x: c[0], y: c[1], f});
        } catch {}
      }
      let fitFeatures = features;
      if (centroids.length > 4) {
        const xs = centroids.map(c => c.x).sort((a: number, b: number) => a - b);
        const ys = centroids.map(c => c.y).sort((a: number, b: number) => a - b);
        const q = (arr: number[], p: number) => arr[Math.floor(arr.length * p)];
        const iqrX = q(xs, 0.75) - q(xs, 0.25);
        const iqrY = q(ys, 0.75) - q(ys, 0.25);
        const loX = q(xs, 0.25) - iqrX * 1.5, hiX = q(xs, 0.75) + iqrX * 1.5;
        const loY = q(ys, 0.25) - iqrY * 1.5, hiY = q(ys, 0.75) + iqrY * 1.5;
        const inliers = centroids.filter(c => c.x >= loX && c.x <= hiX && c.y >= loY && c.y <= hiY);
        if (inliers.length > 0) fitFeatures = inliers.map(c => c.f);
      }
      let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      for (const f of fitFeatures) {
        try {
          const b = pathFn.bounds(f);
          if (b[0][0] < minX) minX = b[0][0];
          if (b[0][1] < minY) minY = b[0][1];
          if (b[1][0] > maxX) maxX = b[1][0];
          if (b[1][1] > maxY) maxY = b[1][1];
        } catch {}
      }
      const pad = 0.15;
      const dx = (maxX - minX) * (1 + pad * 2);
      const dy = (maxY - minY) * (1 + pad * 2);
      const scale = 0.9 / Math.max(dx / W, dy / H);
      const cx = (minX + maxX) / 2, cy = (minY + maxY) / 2;
      const tx = W / 2 - scale * cx, ty = H / 2 - scale * cy;

      // 都道府県パスを薄く
      gLayer.selectAll('path').interrupt().transition().duration(300)
        .attr('fill-opacity', 0.05).attr('stroke-opacity', 0.1);
      gLayer.selectAll('text').attr('opacity', 0);
      gLayer.interrupt();

      // 市区町村レイヤー
      const cityG = gLayer.append('g').attr('class', 'picker-cities');

      function cityDefaultFill(d: any): string {
        const name = cityFullNameGlobal(d);
        if (selectedCities.has(name)) return '#34d399';
        return isUberArea(prefName, name) ? '#e8f4f8' : '#3f3f46';
      }

      cityG.selectAll('path')
        .data(features)
        .enter().append('path')
        .attr('d', pathFn)
        .attr('fill', (d: any) => cityDefaultFill(d))
        .attr('stroke', '#64748b')
        .attr('stroke-width', 0.2 / scale)
        .style('cursor', (d: any) => isUberArea(prefName, cityFullNameGlobal(d)) ? 'pointer' : 'not-allowed')
        .style('opacity', (d: any) => isUberArea(prefName, cityFullNameGlobal(d)) ? 1 : 0.7)
        .on('mouseover', function(_: any, d: any) {
          const name = cityFullNameGlobal(d);
          if (!isUberArea(prefName, name)) return;
          if (!selectedCities.has(name)) pickerD3.select(this).attr('fill', '#a7f3d0');
        })
        .on('mouseout', function(_: any, d: any) {
          pickerD3.select(this).attr('fill', cityDefaultFill(d));
        })
        .on('click', function(_: any, d: any) {
          const name = cityFullNameGlobal(d);
          if (!isUberArea(prefName, name)) return;
          if (selectedCities.has(name)) {
            selectedCities.delete(name);
          } else {
            selectedCities.add(name);
          }
          pickerD3.select(this).attr('fill', cityDefaultFill(d));
          updateCityTags();
          savePrefToStorage();
          updateSubmitState();
        });

      // ラベル
      const seen = new Set<string>();
      const labelFeatures = features.filter((d: any) => {
        const name = cityFullNameGlobal(d);
        if (!name || seen.has(name)) return false;
        seen.add(name);
        try { const c = pathFn.centroid(d); return isFinite(c[0]); } catch { return false; }
      });

      cityG.selectAll('text')
        .data(labelFeatures)
        .enter().append('text')
        .attr('class', 'city-label')
        .attr('x', (d: any) => pathFn.centroid(d)[0])
        .attr('y', (d: any) => pathFn.centroid(d)[1])
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('font-size', `${9 / scale}px`)
        .attr('font-family', 'sans-serif')
        .attr('fill', '#1e293b')
        .attr('stroke', 'white')
        .attr('stroke-width', `${0.3 / scale}px`)
        .attr('pointer-events', 'none')
        .attr('opacity', 0)
        .text((d: any) => {
          const gun = d.properties.N03_003 || '';
          const city = d.properties.N03_004 || '';
          if (gun && city) return city;
          return city || gun;
        });

      // ズーム
      gLayer.transition().duration(500)
        .attr('transform', `translate(${tx},${ty}) scale(${scale})`);

      const baseScale = scale;
      const pickerZoom = pickerD3.zoom().scaleExtent([0.5, 8])
        .on('zoom', (event: any) => {
          const k = event.transform.k;
          const totalScale = baseScale * k;
          gLayer.attr('transform',
            `translate(${tx * k + event.transform.x},${ty * k + event.transform.y}) scale(${totalScale})`);
          const labelOpacity = (k >= 5 && k <= 15) ? Math.min(1, (k - 5) / 0.5) : 0;
          cityG.selectAll('.city-label')
            .attr('opacity', labelOpacity)
            .attr('font-size', `${9 / totalScale}px`)
            .attr('stroke-width', `${0.2 / totalScale}px`);
          cityG.selectAll('path').attr('stroke-width', 0.2 / totalScale);
        });
      setTimeout(() => { svg.call(pickerZoom); }, 550);

      // 既選択エリアをハイライト
      setTimeout(() => updatePickerHighlights(), 100);

      // 都道府県ボタンで戻る
      document.getElementById('picker-btn-pref')!.onclick = () => {
        svg.on('.zoom', null);
        pickerZoom.on('zoom', null);
        cityG.remove();
        gLayer.selectAll('path').interrupt().transition().duration(300)
          .attr('fill-opacity', 1).attr('stroke-opacity', 1).attr('fill', '#e2e8f0');
        gLayer.selectAll('text').attr('opacity', 1);
        gLayer.interrupt().transition().duration(400).attr('transform', '');
        const prefZoomBack = pickerD3.zoom().scaleExtent([1, 8])
          .on('zoom', (event: any) => {
            gLayer.attr('transform', event.transform);
            const k = event.transform.k;
            gLayer.selectAll('text').attr('font-size', `${7 / k}px`);
            gLayer.selectAll('path').attr('stroke-width', 0.5 / k);
          });
        setTimeout(() => { svg.call(prefZoomBack); }, 450);
        // ナビボタン
        const btnP = document.getElementById('picker-btn-pref')!;
        const btnC = document.getElementById('picker-btn-city')!;
        btnP.className = 'bg-blue-600 text-white backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-blue-600 transition-colors';
        btnC.className = 'bg-white/95 text-gray-400 backdrop-blur rounded-lg shadow px-2.5 py-1.5 text-xs font-bold border border-gray-200 transition-colors cursor-not-allowed';
        btnC.textContent = '📍 市区町村';
        (btnC as HTMLButtonElement).disabled = true;
        setTimeout(() => { pickerInCityMode = false; }, 100);
        const count = selectedCities.size;
        document.getElementById('picker-hint')!.textContent = count > 0
          ? `✅ ${count}エリア選択中 — 他の都道府県もタップで追加できます`
          : '都道府県をタップすると市区町村が表示されます';
      };

    } catch {
      document.getElementById('picker-hint')!.textContent = '⚠️ 市区町村データ取得失敗';
    }
  }

  // ===== OCR =====
  const dropzone = document.getElementById('ocr-dropzone')!;
  const fileInput = document.getElementById('ocr-file') as HTMLInputElement;
  dropzone.addEventListener('click', () => fileInput.click());
  dropzone.addEventListener('dragover', (e) => { e.preventDefault(); dropzone.classList.add('bg-violet-100'); });
  dropzone.addEventListener('dragleave', () => { dropzone.classList.remove('bg-violet-100'); });
  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('bg-violet-100');
    if (e.dataTransfer?.files?.length) {
      fileInput.files = e.dataTransfer.files;
      handleOCRFile(e.dataTransfer.files[0]);
    }
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) handleOCRFile(fileInput.files[0]);
  });

  async function handleOCRFile(file: File) {
    const reader = new FileReader();
    reader.onload = (e) => {
      (document.getElementById('ocr-thumb') as HTMLImageElement).src = e.target?.result as string;
      document.getElementById('ocr-placeholder')!.classList.add('hidden');
      document.getElementById('ocr-preview-img')!.classList.remove('hidden');
    };
    reader.readAsDataURL(file);

    document.getElementById('ocr-processing')!.classList.remove('hidden');
    document.getElementById('ocr-result')!.classList.add('hidden');
    document.getElementById('ocr-error')!.classList.add('hidden');
    document.getElementById('ocr-weekly-warning')!.classList.add('hidden');
    const progressBar = document.getElementById('ocr-progress-bar') as HTMLElement;
    progressBar.style.width = '10%';

    try {
      if (!(window as any).Tesseract) {
        const s = document.createElement('script');
        s.src = 'https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js';
        document.head.appendChild(s);
        await new Promise<void>((res, rej) => { s.onload = () => res(); s.onerror = () => rej(); });
      }
      progressBar.style.width = '30%';

      const Tesseract = (window as any).Tesseract;
      const result = await Tesseract.recognize(file, 'jpn+eng', {
        logger: (m: any) => {
          if (m.status === 'recognizing text' && m.progress) {
            progressBar.style.width = `${30 + m.progress * 60}%`;
          }
        },
      });
      progressBar.style.width = '95%';

      const parsed = parseUberScreenshot(result.data.text);
      // 画像ピクセル分析で棒グラフの選択日を検出
      const barResult = await detectSelectedBarDay(file);

      // 週間画像の検出 → 警告
      const weeklyWarn = document.getElementById('ocr-weekly-warning')!;
      weeklyWarn.classList.add('hidden');
      if (barResult.isWeekly) {
        weeklyWarn.classList.remove('hidden');
        console.log('[BAR] weekly image detected, showing warning');
      }

      if (barResult.dayOfWeek) {
        parsed.dayOfWeek = barResult.dayOfWeek;
        console.log('[BAR] detected selected day:', barResult.dayOfWeek);
      }
      progressBar.style.width = '100%';

      if (parsed.earnings > 0 || parsed.hours > 0) {
        (document.getElementById('ocr-earnings') as HTMLInputElement).value = String(parsed.earnings);
        (document.getElementById('ocr-hours') as HTMLInputElement).value = String(parsed.hoursInt);
        (document.getElementById('ocr-minutes') as HTMLInputElement).value = String(parsed.minutesInt);
        (document.getElementById('ocr-deliveries') as HTMLInputElement).value = String(parsed.deliveries || '');
        (document.getElementById('ocr-base-fare') as HTMLInputElement).value = String(parsed.baseFare || '');
        (document.getElementById('ocr-promotion') as HTMLInputElement).value = String(parsed.promotion || '');
        // 曜日をセット（棒グラフ検出 > OCRテキスト検出 > 今日の曜日）
        const detectedDow = parsed.dayOfWeek || ['sun','mon','tue','wed','thu','fri','sat'][new Date().getDay()];
        (document.getElementById('ocr-dow') as HTMLInputElement).value = detectedDow;
        selectDowButton(detectedDow);
        updateOCRHourly();
        document.getElementById('ocr-processing')!.classList.add('hidden');
        document.getElementById('ocr-result')!.classList.remove('hidden');
        // 週間画像の場合は投稿できないようにする
        ocrDataReady = !barResult.isWeekly;
        updateSubmitState();
      } else {
        throw new Error('データを読み取れませんでした');
      }
    } catch {
      document.getElementById('ocr-processing')!.classList.add('hidden');
      document.getElementById('ocr-weekly-warning')!.classList.add('hidden');
      const errorEl = document.getElementById('ocr-error')!;
      errorEl.textContent = '⚠️ 読み取り失敗。数値を手動で入力してください。';
      errorEl.classList.remove('hidden');
      // 失敗時も今日の曜日をデフォルトセット
      const defaultDow = ['sun','mon','tue','wed','thu','fri','sat'][new Date().getDay()];
      (document.getElementById('ocr-dow') as HTMLInputElement).value = defaultDow;
      selectDowButton(defaultDow);
      document.getElementById('ocr-result')!.classList.remove('hidden');
      ocrDataReady = true;
      updateSubmitState();
    }
  }

  /**
   * 画像ピクセル分析で Uber Eats 棒グラフの「選択中の日」を検出する。
   *
   * 戦略:
   *  1. 画像上部を走査し、青系ピクセルが集中する Y 帯を動的に検出
   *     （画面レイアウトのずれに対応）
   *  2. その帯を 7 分割し、各列の「明るい青」と「暗い青」のピクセル数を計測
   *  3. 全列が同じ明るさ → 週間表示（isWeekly=true）
   *  4. 1列だけ明るい → その列が選択中の曜日
   *
   * 返り値: { dayOfWeek: string, isWeekly: boolean }
   */
  async function detectSelectedBarDay(file: File): Promise<{ dayOfWeek: string; isWeekly: boolean }> {
    return new Promise((resolve) => {
      const img = new Image();
      img.onload = () => {
        try {
          const canvas = document.createElement('canvas');
          const W = img.naturalWidth;
          const H = img.naturalHeight;
          canvas.width = W;
          canvas.height = H;
          const ctx = canvas.getContext('2d')!;
          ctx.drawImage(img, 0, 0);

          // ===== STEP 1: 青系ピクセルが集中する Y 帯を動的に検出 =====
          // 画像上半分 (0% 〜 40%) をスキャンして、青ピクセルの Y 分布を調べる
          const scanTop = 0;
          const scanBottom = Math.floor(H * 0.40);
          const fullData = ctx.getImageData(0, scanTop, W, scanBottom).data;

          // Y ごとに青ピクセル数をカウント
          const blueByRow: number[] = new Array(scanBottom).fill(0);
          for (let y = 0; y < scanBottom; y++) {
            for (let x = 0; x < W; x++) {
              const idx = (y * W + x) * 4;
              const r = fullData[idx], g = fullData[idx + 1], b = fullData[idx + 2];
              // 青系（棒グラフ）: b>80, b>r, 背景黒や白テキストを除外
              const sum = r + g + b;
              if (b > 80 && b > r && sum > 120 && sum < 650) {
                blueByRow[y]++;
              }
            }
          }

          // 青ピクセルが多い行の範囲を見つける（棒グラフの Y 帯）
          const maxRow = Math.max(...blueByRow);
          const threshold = maxRow * 0.15; // 最大の 15% 以上ある行を棒グラフ領域とみなす
          let barYStart = -1, barYEnd = -1;
          for (let y = 0; y < scanBottom; y++) {
            if (blueByRow[y] > threshold) {
              if (barYStart < 0) barYStart = y;
              barYEnd = y;
            }
          }

          if (barYStart < 0 || barYEnd - barYStart < 5) {
            console.log('[BAR] no bar chart region found');
            resolve({ dayOfWeek: '', isWeekly: false });
            return;
          }

          console.log('[BAR] detected bar Y range:', barYStart, '-', barYEnd, '(H=' + H + ')');

          // ===== STEP 2: 棒グラフの Y 帯を 7 分割して色分析 =====
          const xMargin = Math.floor(W * 0.03);
          const regionW = W - xMargin * 2;
          const regionH = barYEnd - barYStart;
          const barData = ctx.getImageData(xMargin, barYStart, regionW, regionH).data;
          const colWidth = Math.floor(regionW / 7);

          // 各列の「明るい青」と「暗い青」ピクセル数
          const brightCounts: number[] = [];
          const darkCounts: number[] = [];
          const anyBlueCounts: number[] = [];

          for (let col = 0; col < 7; col++) {
            let bright = 0, dark = 0, anyBlue = 0;
            const cxStart = col * colWidth;
            const cxEnd = cxStart + colWidth;

            for (let y = 0; y < regionH; y++) {
              for (let x = cxStart; x < cxEnd; x++) {
                const idx = (y * regionW + x) * 4;
                const r = barData[idx], g = barData[idx + 1], b = barData[idx + 2];
                const sum = r + g + b;

                // 背景黒(sum<80) やテキスト白(sum>650) を除外
                if (sum < 80 || sum > 650) continue;

                // 青系のピクセル
                if (b > 80 && b > r) {
                  anyBlue++;
                  // 明るい青 vs 暗い青を判定
                  // 明るい青（選択中）: 青成分が高く、全体的に明るめ
                  //   例: rgb(130,160,220) 〜 rgb(170,190,245)
                  // 暗い青（非選択）: 全体的に暗い
                  //   例: rgb(60,65,85) 〜 rgb(90,100,130)
                  if (b > 140 && sum > 300) {
                    bright++;
                  } else if (sum < 300) {
                    dark++;
                  }
                }
              }
            }
            brightCounts.push(bright);
            darkCounts.push(dark);
            anyBlueCounts.push(anyBlue);
          }

          console.log('[BAR] bright:', brightCounts);
          console.log('[BAR] dark:', darkCounts);
          console.log('[BAR] anyBlue:', anyBlueCounts);

          // ===== STEP 3: 週間表示 vs 日別表示を判定 =====
          const totalBright = brightCounts.reduce((a, b) => a + b, 0);
          const totalDark = darkCounts.reduce((a, b) => a + b, 0);

          // 棒があるカラム（ある程度の青ピクセルがある列）を特定
          const minForBar = Math.max(...anyBlueCounts) * 0.05;
          const barsWithData = anyBlueCounts.filter(c => c > minForBar).length;

          // 明るい青ピクセルがある列の数をカウント
          const brightThreshold = totalBright > 0 ? Math.max(...brightCounts) * 0.3 : 0;
          const brightCols = brightCounts.filter(c => c > brightThreshold).length;

          console.log('[BAR] barsWithData:', barsWithData, 'brightCols:', brightCols,
            'totalBright:', totalBright, 'totalDark:', totalDark);

          // 週間表示判定: 暗い棒がほぼ無く、データのある棒が全て明るい
          if (totalDark < totalBright * 0.1 && barsWithData >= 2 && brightCols >= barsWithData) {
            console.log('[BAR] WEEKLY view detected (all bars are bright blue)');
            resolve({ dayOfWeek: '', isWeekly: true });
            return;
          }

          // 明るい棒が複数あって暗い棒が少ない → 週間
          if (brightCols >= 3 && totalDark < totalBright * 0.3) {
            console.log('[BAR] WEEKLY view detected (multiple bright bars, few dark)');
            resolve({ dayOfWeek: '', isWeekly: true });
            return;
          }

          // ===== STEP 4: 1列だけ明るい → 選択中の曜日を特定 =====
          const maxBright = Math.max(...brightCounts);
          if (maxBright < 10) {
            console.log('[BAR] no bright bars detected');
            resolve({ dayOfWeek: '', isWeekly: false });
            return;
          }

          const selectedCol = brightCounts.indexOf(maxBright);
          // 2番目との差を確認
          const sorted = [...brightCounts].sort((a, b) => b - a);
          if (sorted[1] > 0 && sorted[0] / sorted[1] < 1.5) {
            console.log('[BAR] ambiguous: top two close', sorted[0], 'vs', sorted[1]);
            // それでも暗い棒が十分あれば日別表示かもしれない
            if (totalDark > totalBright * 0.5) {
              // 暗い棒が多い → 日別表示で2列の棒が近い高さ
              // 棒の高さ（anyBlue）が最大の列を選ぶ代わりに、明るい列の中で最大を使う
              console.log('[BAR] treating as daily (dark bars exist)');
            } else {
              resolve({ dayOfWeek: '', isWeekly: false });
              return;
            }
          }

          // 開始日の曜日から選択曜日を計算
          const dayKeys = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
          if ((window as any).__ocrStartDow !== undefined) {
            const startDow = (window as any).__ocrStartDow as number;
            const selectedDow = (startDow + selectedCol) % 7;
            console.log('[BAR] col:', selectedCol, 'startDow:', dayKeys[startDow], '→', dayKeys[selectedDow]);
            resolve({ dayOfWeek: dayKeys[selectedDow], isWeekly: false });
          } else {
            console.log('[BAR] no start dow info available');
            resolve({ dayOfWeek: '', isWeekly: false });
          }
        } catch (err) {
          console.log('[BAR] pixel analysis error:', err);
          resolve({ dayOfWeek: '', isWeekly: false });
        }
      };
      img.onerror = () => resolve({ dayOfWeek: '', isWeekly: false });
      img.src = URL.createObjectURL(file);
    });
  }

  function parseUberScreenshot(text: string) {
    const result = { earnings: 0, hours: 0, hoursInt: 0, minutesInt: 0, deliveries: 0, baseFare: 0, promotion: 0, dayOfWeek: '' as string };

    // デバッグ: OCR生テキスト出力
    console.log('[OCR] raw text:', text);

    // 前処理: 全角数字→半角、全角カンマ→半角、余分なスペース圧縮
    const t = text
      .replace(/[０-９]/g, c => String.fromCharCode(c.charCodeAt(0) - 0xFF10 + 0x30))
      .replace(/[，]/g, ',')
      .replace(/[ \t]+/g, ' ');

    // 行ごとに分割して解析（OCRは行単位で出力するため）
    const lines = t.split(/\n/).map(l => l.trim()).filter(Boolean);
    console.log('[OCR] lines:', lines);

    // ヘルパー: 行から金額を抽出
    function extractAmount(line: string): number {
      const m = line.match(/[¥￥\\Y]\s?([\d,]+)/);
      if (m) return parseInt(m[1].replace(/,/g, ''));
      // ¥記号なしの金額（行末の数字のみ）
      const m2 = line.match(/([\d,]{2,})$/);
      if (m2) return parseInt(m2[1].replace(/,/g, ''));
      return 0;
    }

    // まず全テキストを1つにまとめてパターンマッチ（1行で来る場合の対策）
    const flat = lines.join(' ');

    // 正味の料金（ラベルの直後の金額を取る）
    for (const pat of [/正味.{0,3}料金\s*[¥￥\\Y]\s?([\d,]+)/, /正味.{0,3}料金\s+([\d,]{2,})/]) {
      const m = flat.match(pat);
      if (m) { result.baseFare = parseInt(m[1].replace(/,/g, '')); console.log('[OCR] baseFare:', result.baseFare); break; }
    }

    // プロモーション（non-greedy + ¥有り/無しの両方に対応）
    for (const pat of [/(?:プロモ|ブロモ|promotion)\S*\s*[¥￥\\Y]\s?([\d,]+)/i, /(?:プロモ|ブロモ|promotion)\S*\s+([\d,]{2,})/i]) {
      const m = flat.match(pat);
      if (m) { result.promotion = parseInt(m[1].replace(/,/g, '')); console.log('[OCR] promotion:', result.promotion); break; }
    }

    // 売り上げ総額
    for (const pat of [/売.{0,3}上.{0,3}総額\s*[¥￥\\Y]\s?([\d,]+)/, /売.{0,3}上.{0,3}総額\s+([\d,]{2,})/]) {
      const m = flat.match(pat);
      if (m) { result.earnings = parseInt(m[1].replace(/,/g, '')); console.log('[OCR] earnings (total):', result.earnings); break; }
    }

    // 売上が未検出の場合: 全金額から最大値
    if (!result.earnings) {
      const amountPat = /[¥￥\\Y]\s?([\d,]+)/g;
      const allAmounts: number[] = [];
      let am;
      while ((am = amountPat.exec(flat)) !== null) allAmounts.push(parseInt(am[1].replace(/,/g, '')));
      // ¥記号なしの行末金額も拾う
      for (const line of lines) {
        const m2 = line.match(/([\d,]{4,})$/);
        if (m2) allAmounts.push(parseInt(m2[1].replace(/,/g, '')));
      }
      if (allAmounts.length > 0) {
        allAmounts.sort((a, b) => b - a);
        result.earnings = allAmounts[0];
        console.log('[OCR] earnings (max fallback):', result.earnings);
      }
    }

    // 各行を解析（時間・件数）
    for (const line of lines) {
      // オンライン時間
      if (!result.hours) {
        for (const pat of [/(\d+)\s*[時hH]\s*[間]?\s*(\d+)\s*[分mM]/, /(\d+)\s*時間\s*(\d+)\s*分/]) {
          const m = line.match(pat);
          if (m) {
            result.hoursInt = parseInt(m[1]);
            result.minutesInt = parseInt(m[2]);
            result.hours = result.hoursInt + result.minutesInt / 60;
            console.log('[OCR] time:', result.hoursInt, 'h', result.minutesInt, 'm', '<-', line);
            break;
          }
        }
      }

      // 乗車/配達件数
      if (!result.deliveries) {
        for (const pat of [/乗車\s*(\d+)(?!\s*[時hH])/, /(?:配達|rides?)\s+(\d+)/, /(\d+)\s*(?:件|回)/]) {
          const m = line.match(pat);
          if (m) {
            result.deliveries = parseInt(m[1]);
            console.log('[OCR] deliveries:', result.deliveries, '<-', line);
            break;
          }
        }
      }
    }

    // 乗車件数がまだ未検出: 全テキストからも探す（時間の数字を誤検出しないよう負の先読み）
    if (!result.deliveries) {
      for (const pat of [/乗車\s*(\d+)(?!\s*[時hH])/, /(?:配達|rides?)\s+(\d+)/, /(\d+)\s*(?:件|回)/]) {
        const m = flat.match(pat);
        if (m) { result.deliveries = parseInt(m[1]); console.log('[OCR] deliveries (flat):', result.deliveries); break; }
      }
    }

    // OCRで「乗車」と数字が別の行に来るケース
    if (!result.deliveries) {
      for (let i = 0; i < lines.length; i++) {
        if (/乗車/.test(lines[i])) {
          // 同行に数字あるか（時間以外）
          const m = lines[i].match(/(\d+)/);
          if (m && !/時/.test(lines[i])) { result.deliveries = parseInt(m[1]); break; }
          // 次行をチェック: 時間パターンの後ろに残る数字、または数字だけの行
          if (i + 1 < lines.length) {
            const nextLine = lines[i+1].trim();
            if (/^\d+$/.test(nextLine)) {
              result.deliveries = parseInt(nextLine);
              console.log('[OCR] deliveries (next line pure number):', result.deliveries);
              break;
            }
            // 「4 時間 24 分 12」のように時間+件数が混在する行
            const afterTime = nextLine.replace(/\d+\s*[時hH]\s*[間]?\s*\d+\s*[分mM]?/, '').trim();
            if (afterTime && /^\d+$/.test(afterTime)) {
              result.deliveries = parseInt(afterTime);
              console.log('[OCR] deliveries (after time):', result.deliveries);
              break;
            }
          }
        }
      }
    }

    // 売上が未検出の場合: 全金額から最大値
    if (!result.earnings && allAmounts.length > 0) {
      allAmounts.sort((a, b) => b - a);
      result.earnings = allAmounts[0];
      console.log('[OCR] earnings (max fallback):', result.earnings);
    }

    // 正味+プロモ=売上 の整合性チェック → 片方が欠けていたら計算で補完
    if (result.earnings > 0 && result.baseFare > 0 && !result.promotion) {
      result.promotion = result.earnings - result.baseFare;
      if (result.promotion < 0) result.promotion = 0;
    }
    if (result.earnings > 0 && result.promotion > 0 && !result.baseFare) {
      result.baseFare = result.earnings - result.promotion;
      if (result.baseFare < 0) result.baseFare = 0;
    }

    // 日付検出 → 曜日を自動判定
    // Uber Eats画面のヘッダーに「3月30日 - 4月6日」（週範囲）or 単独の日付が表示される
    // 棒グラフの下に「30 月 31 火 1 水 ...」と全曜日が並ぶため、
    // OCRだけでは「どの日が選択中か」判別不可 → 手動セレクターで補完
    const dayKeys = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
    const now = new Date();
    const currentYear = now.getFullYear();

    // パターン1: 「○月○日」形式（ただし範囲「○月○日 - ○月○日」はスキップ）
    // 範囲でない単独の日付のみマッチ
    const dateRangePat = /(\d{1,2})\s*月\s*(\d{1,2})\s*日\s*[-\-〜~]/;
    const rangeMatch = flat.match(dateRangePat);
    const isRange = !!rangeMatch;
    // 範囲の場合: 開始日の曜日を保存（棒グラフ分析用）
    if (isRange && rangeMatch) {
      const rMo = parseInt(rangeMatch[1]), rDa = parseInt(rangeMatch[2]);
      if (rMo >= 1 && rMo <= 12 && rDa >= 1 && rDa <= 31) {
        const rDt = new Date(currentYear, rMo - 1, rDa);
        if (rDt > now) rDt.setFullYear(currentYear - 1);
        (window as any).__ocrStartDow = rDt.getDay();
        console.log('[OCR] date range start:', rMo + '/' + rDa, 'dow:', dayKeys[rDt.getDay()]);
      }
    }
    if (!isRange) {
      const datePat1 = flat.match(/(\d{1,2})\s*月\s*(\d{1,2})\s*日/);
      if (datePat1) {
        const mo = parseInt(datePat1[1]), da = parseInt(datePat1[2]);
        if (mo >= 1 && mo <= 12 && da >= 1 && da <= 31) {
          const dt = new Date(currentYear, mo - 1, da);
          if (dt > now) dt.setFullYear(currentYear - 1);
          result.dayOfWeek = dayKeys[dt.getDay()];
          console.log('[OCR] date detected:', mo + '/' + da, '→', result.dayOfWeek);
        }
      }
    }
    // パターン2: 「○/○」形式（年なし、範囲でない場合のみ）
    if (!result.dayOfWeek) {
      const slashRange = /(\d{1,2})\/(\d{1,2})\s*[-\-〜~]/;
      if (!slashRange.test(flat)) {
        const datePat2 = flat.match(/(\d{1,2})\/(\d{1,2})/);
        if (datePat2) {
          const mo = parseInt(datePat2[1]), da = parseInt(datePat2[2]);
          if (mo >= 1 && mo <= 12 && da >= 1 && da <= 31) {
            const dt = new Date(currentYear, mo - 1, da);
            if (dt > now) dt.setFullYear(currentYear - 1);
            result.dayOfWeek = dayKeys[dt.getDay()];
            console.log('[OCR] date detected (slash):', mo + '/' + da, '→', result.dayOfWeek);
          }
        }
      }
    }
    // パターン3: 曜日テキスト直接検出（「月曜日」「(火)」など）
    // 注: 棒グラフの「30 月 31 火 ...」ラベルは複数あるのでスキップ
    if (!result.dayOfWeek) {
      const dowMap: Record<string, string> = { '日': 'sun', '月': 'mon', '火': 'tue', '水': 'wed', '木': 'thu', '金': 'fri', '土': 'sat' };
      // 「月曜日」「(火)」のような明確な曜日表現のみマッチ
      const dowPat = flat.match(/([日月火水木金土])\s*曜/);
      if (dowPat && dowMap[dowPat[1]]) {
        result.dayOfWeek = dowMap[dowPat[1]];
        console.log('[OCR] dayOfWeek direct:', dowPat[0], '→', result.dayOfWeek);
      }
    }
    console.log('[OCR] dayOfWeek result:', result.dayOfWeek || '(未検出 → 手動選択)');

    console.log('[OCR] parsed result:', result);
    return result;
  }

  // 曜日ボタン選択
  function selectDowButton(dow: string) {
    document.querySelectorAll('#ocr-dow-buttons .dow-btn').forEach((btn) => {
      const b = btn as HTMLButtonElement;
      if (b.dataset.dow === dow) {
        b.classList.remove('bg-white', 'border-gray-200');
        b.classList.add('bg-blue-600', 'text-white', 'border-blue-600');
      } else {
        b.classList.remove('bg-blue-600', 'text-white', 'border-blue-600');
        b.classList.add('bg-white', 'border-gray-200');
        // 土曜と日曜の色を復元
        if (b.dataset.dow === 'sat') { b.classList.add('text-blue-600'); b.classList.remove('text-gray-600'); }
        else if (b.dataset.dow === 'sun') { b.classList.add('text-red-500'); b.classList.remove('text-gray-600'); }
        else { b.classList.add('text-gray-600'); }
      }
    });
    (document.getElementById('ocr-dow') as HTMLInputElement).value = dow;
  }

  // 曜日ボタンのクリックイベント
  document.querySelectorAll('#ocr-dow-buttons .dow-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      selectDowButton((btn as HTMLButtonElement).dataset.dow!);
    });
  });

  function updateOCRHourly() {
    const earnings = parseFloat((document.getElementById('ocr-earnings') as HTMLInputElement).value) || 0;
    const hours = parseFloat((document.getElementById('ocr-hours') as HTMLInputElement).value) || 0;
    const minutes = parseFloat((document.getElementById('ocr-minutes') as HTMLInputElement).value) || 0;
    const totalHours = hours + minutes / 60;
    const hourlyEl = document.getElementById('ocr-hourly') as HTMLInputElement;
    if (totalHours > 0 && earnings > 0) {
      hourlyEl.value = `¥${Math.round(earnings / totalHours).toLocaleString()}`;
    } else {
      hourlyEl.value = '-';
    }
  }

  ['ocr-earnings', 'ocr-hours', 'ocr-minutes'].forEach(id => {
    document.getElementById(id)!.addEventListener('input', () => {
      updateOCRHourly();
      ocrDataReady = true;
      updateSubmitState();
    });
  });

  // ===== フォーム送信 =====
  document.getElementById('data-form')!.addEventListener('submit', (e) => {
    e.preventDefault();
    const errorEl = document.getElementById('error-msg')!;

    // ハニーポット
    if ((document.getElementById('website') as HTMLInputElement).value) {
      document.getElementById('data-form')!.classList.add('hidden');
      document.getElementById('success-msg')!.classList.remove('hidden');
      return;
    }
    // 速度チェック
    if (Date.now() - formLoadTime < 3000) {
      document.getElementById('data-form')!.classList.add('hidden');
      document.getElementById('success-msg')!.classList.remove('hidden');
      return;
    }
    // レート制限
    const rl = checkRateLimit();
    if (!rl.ok) {
      document.getElementById('rate-limit-msg')!.classList.remove('hidden');
      document.getElementById('rate-timer')!.textContent = `${rl.waitSec}秒`;
      const interval = setInterval(() => {
        const check = checkRateLimit();
        if (check.ok) { clearInterval(interval); document.getElementById('rate-limit-msg')!.classList.add('hidden'); }
        else { document.getElementById('rate-timer')!.textContent = `${check.waitSec}秒`; }
      }, 1000);
      return;
    }

    // データ収集
    const pref = (document.getElementById('prefecture') as HTMLInputElement).value;
    const cityMulti = (document.getElementById('city-multi') as HTMLInputElement).value;
    const cities = cityMulti ? cityMulti.split(',').filter(Boolean) : [];
    const vehicle = (document.querySelector('input[name="vehicle"]:checked') as HTMLInputElement)?.value;
    const earnings = parseFloat((document.getElementById('ocr-earnings') as HTMLInputElement).value) || 0;
    const hoursVal = parseFloat((document.getElementById('ocr-hours') as HTMLInputElement).value) || 0;
    const minutesVal = parseFloat((document.getElementById('ocr-minutes') as HTMLInputElement).value) || 0;
    const hours = hoursVal + minutesVal / 60;
    const deliveries = parseInt((document.getElementById('ocr-deliveries') as HTMLInputElement).value) || 0;
    const baseFare = parseInt((document.getElementById('ocr-base-fare') as HTMLInputElement).value) || 0;
    const promotion = parseInt((document.getElementById('ocr-promotion') as HTMLInputElement).value) || 0;

    // バリデーション
    if (!pref || cities.length === 0) { errorEl.textContent = '⚠️ 配達エリアを地図から選んでください'; errorEl.classList.remove('hidden'); return; }
    if (!vehicle) { errorEl.textContent = '⚠️ 乗り物を選んでください'; errorEl.classList.remove('hidden'); return; }
    if (hours <= 0) { errorEl.textContent = '⚠️ オンライン時間を入力してください'; errorEl.classList.remove('hidden'); return; }
    if (earnings <= 0) { errorEl.textContent = '⚠️ 売上を入力してください'; errorEl.classList.remove('hidden'); return; }

    const rate = Math.round(earnings / hours);
    if (rate > 8000 || rate < 100) {
      errorEl.textContent = '⚠️ 時給が現実的な範囲外です。入力内容を確認してください。';
      errorEl.classList.remove('hidden');
      return;
    }
    errorEl.classList.add('hidden');

    // 曜日はセレクターから取得（OCR検出 or ユーザー手動選択）
    const dayOfWeek = (document.getElementById('ocr-dow') as HTMLInputElement).value || ['sun','mon','tue','wed','thu','fri','sat'][new Date().getDay()];

    // 選択した全市区町村に対してそれぞれエントリを作成
    const entries = cities.map(cityName => ({
      prefecture: pref, city: cityName, vehicle,
      dayType: dayOfWeek,
      timeSlot: 'unknown',
      hours: Math.round(hours * 10) / 10, earnings,
      deliveries: deliveries || null,
      baseFare: baseFare || null,
      promotion: promotion || null,
      hourlyRate: rate,
      memo: '',
      timestamp: new Date().toISOString(),
      dayOfWeek,
      fromOCR: true,
    }));

    // 重複チェック（最初のエントリで代表チェック）
    if (checkDuplicate(entries[0])) {
      errorEl.textContent = '⚠️ 同じ内容のデータが本日すでに投稿されています';
      errorEl.classList.remove('hidden');
      return;
    }

    // 保存（全エリア分をまとめて追加）
    const existing = JSON.parse(localStorage.getItem('uber_data') ?? '[]');
    const prevCount = existing.length;
    localStorage.setItem('uber_data', JSON.stringify([...existing, ...entries]));
    localStorage.setItem('uber_last_submit', String(Date.now()));

    const newCount = prevCount + entries.length;

    // 成功
    const successSub = document.getElementById('success-sub')!;
    successSub.textContent = `累計 ${newCount}件のデータ提供 — ありがとうございます！`;

    document.getElementById('data-form')!.classList.add('hidden');
    document.getElementById('success-msg')!.classList.remove('hidden');
    window.dispatchEvent(new CustomEvent('uber-data-updated'));
  });

  // リセット
  document.getElementById('reset-btn')!.addEventListener('click', () => {
    document.getElementById('data-form')!.classList.remove('hidden');
    document.getElementById('success-msg')!.classList.add('hidden');
    // OCRリセット
    document.getElementById('ocr-result')!.classList.add('hidden');
    document.getElementById('ocr-placeholder')!.classList.remove('hidden');
    document.getElementById('ocr-preview-img')!.classList.add('hidden');
    (document.getElementById('ocr-file') as HTMLInputElement).value = '';
    ocrDataReady = false;
    // 乗り物・エリアはlocalStorageから復元済みなのでそのまま
    updateSubmitState();
    formLoadTime = Date.now();
  });

  // ===== 初期化 =====
  restoreSavedPrefs();
  initPicker();
</script>
