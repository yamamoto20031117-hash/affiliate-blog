  function isUberArea(prefName: string, cityName: string): boolean {
    const cities = UBER_AREA[prefName];
    if (!cities) return false;
    if (cities.has(cityName)) return true;
    for (const c of cities) {
      if (cityName.startsWith(c) || c.startsWith(cityName)) return true;
    }
    return false;
  }

