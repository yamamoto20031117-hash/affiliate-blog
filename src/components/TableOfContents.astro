---
// 目次はJS側でh2/h3を自動収集して描画します
---

<div id="toc-wrapper" class="hidden bg-blue-50 border border-primary-200 rounded-xl p-4 mb-8">
  <button
    id="toc-toggle"
    class="flex items-center justify-between w-full text-left"
    aria-expanded="true"
  >
    <span class="font-bold text-primary-800 flex items-center gap-2 text-sm">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 6h16M4 10h16M4 14h10M4 18h10"/>
      </svg>
      目次
    </span>
    <svg id="toc-chevron" class="w-4 h-4 text-primary-600 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
    </svg>
  </button>
  <nav id="toc-content" class="mt-3">
    <ul id="toc-list" class="space-y-1 text-sm"></ul>
  </nav>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const article = document.querySelector('article .prose');
    if (!article) return;

    const headings = article.querySelectorAll('h2, h3');
    if (headings.length < 2) return;

    const tocWrapper = document.getElementById('toc-wrapper')!;
    const tocList = document.getElementById('toc-list')!;
    const tocToggle = document.getElementById('toc-toggle')!;
    const tocContent = document.getElementById('toc-content')!;
    const tocChevron = document.getElementById('toc-chevron')!;

    headings.forEach((heading, i) => {
      if (!heading.id) heading.id = `heading-${i}`;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent || '';
      a.className = heading.tagName === 'H2'
        ? 'block text-primary-700 hover:text-primary-900 hover:underline py-0.5'
        : 'block text-primary-600 hover:text-primary-800 hover:underline py-0.5 pl-4';
      li.appendChild(a);
      tocList.appendChild(li);
    });

    tocWrapper.classList.remove('hidden');

    tocToggle.addEventListener('click', () => {
      const isOpen = tocContent.style.display !== 'none';
      tocContent.style.display = isOpen ? 'none' : '';
      tocChevron.style.transform = isOpen ? 'rotate(180deg)' : '';
    });
  });
</script>
