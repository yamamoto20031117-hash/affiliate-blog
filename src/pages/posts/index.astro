---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const sortedPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="記事一覧" description="すべてのレビュー・おすすめ記事をご紹介しています。">
  <div class="max-w-5xl mx-auto px-4 py-10">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">記事一覧</h1>
    <p class="text-sm text-gray-500 mb-8">{sortedPosts.length}件の記事</p>

    {sortedPosts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {sortedPosts.map(post => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description ?? ''}
            pubDate={post.data.pubDate}
            slug={post.slug}
            heroImage={post.data.heroImage}
            category={post.data.category}
            tags={post.data.tags}
          />
        ))}
      </div>
    ) : (
      <p class="text-gray-400 text-center py-16">まだ記事がありません。</p>
    )}
  </div>
</BaseLayout>
